rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isNonEmptyString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function isStringWithMax(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function isAllowedProductSku(value) {
      return value == "paper-print";
    }

    function isAllowedSource(value) {
      return value == "landing" ||
             value == "dashboard" ||
             value == "tree" ||
             value == "demo-tree";
    }

    function isAllowedView(value) {
      return value == "tree" ||
             value == "calendar" ||
             value == "globe";
    }

    function isAllowedPrintStyle(value) {
      return value == "Classic" ||
             value == "Ornate" ||
             value == "Minimal";
    }

    function isAllowedPaperFinish(value) {
      return value == "Matte" ||
             value == "Satin" ||
             value == "Gloss";
    }

    function isAllowedPrintSize(value) {
      return value == "A3" ||
             value == "A2" ||
             value == "Custom";
    }

    function isValidOrderOptions(options, productSku) {
      return options is map &&
             options.keys().hasOnly(["printStyle", "paperFinish", "printSize"]) &&
             (
               productSku == "paper-print"
                 ? ("printStyle" in options &&
                    "paperFinish" in options &&
                    "printSize" in options &&
                    isAllowedPrintStyle(options.printStyle) &&
                    isAllowedPaperFinish(options.paperFinish) &&
                    isAllowedPrintSize(options.printSize))
                 : false
             );
    }

    function isValidOrderContext(context) {
      return context is map &&
             context.keys().hasAll(["source", "view", "treeId", "treeName", "originPath"]) &&
             context.keys().hasOnly(["source", "view", "treeId", "treeName", "originPath"]) &&
             isAllowedSource(context.source) &&
             isAllowedView(context.view) &&
             isStringWithMax(context.treeId, 120) &&
             isStringWithMax(context.treeName, 160) &&
             isNonEmptyString(context.originPath, 700);
    }

    function hasValidUnitPrice(productSku, unitPrice) {
      return (productSku == "paper-print" && unitPrice == 69);
    }

    function hasValidDiscountPercent(productSku, discountPercent) {
      return discountPercent == 0;
    }

    function isValidShippingAddress(address) {
      return address is map &&
             address.keys().hasAll(["line1", "line2", "city", "region", "postalCode", "country"]) &&
             address.keys().hasOnly(["line1", "line2", "city", "region", "postalCode", "country"]) &&
             isNonEmptyString(address.line1, 160) &&
             isStringWithMax(address.line2, 160) &&
             isNonEmptyString(address.city, 80) &&
             isNonEmptyString(address.region, 80) &&
             isNonEmptyString(address.postalCode, 20) &&
             isNonEmptyString(address.country, 80);
    }

    function isValidStoreOrder(data) {
      return data.keys().hasAll([
               "userId",
               "userEmail",
               "userDisplayName",
               "contactName",
               "contactEmail",
               "contactPhone",
               "shippingAddress",
               "productSku",
               "productLabel",
               "currency",
               "unitPrice",
               "quantity",
               "subtotal",
               "discountPercent",
               "discountAmount",
               "total",
               "options",
               "note",
               "context",
               "status",
               "createdAt",
               "updatedAt"
             ]) &&
             data.keys().hasOnly([
               "userId",
               "userEmail",
               "userDisplayName",
               "contactName",
               "contactEmail",
               "contactPhone",
               "shippingAddress",
               "productSku",
               "productLabel",
               "currency",
               "unitPrice",
               "quantity",
               "subtotal",
               "discountPercent",
               "discountAmount",
               "total",
               "options",
               "note",
               "context",
               "status",
               "createdAt",
               "updatedAt"
             ]) &&
             isNonEmptyString(data.userId, 120) &&
             isNonEmptyString(data.userEmail, 160) &&
             isStringWithMax(data.userDisplayName, 120) &&
             isNonEmptyString(data.contactName, 120) &&
             isNonEmptyString(data.contactEmail, 160) &&
             isNonEmptyString(data.contactPhone, 32) &&
             isValidShippingAddress(data.shippingAddress) &&
             isAllowedProductSku(data.productSku) &&
             isNonEmptyString(data.productLabel, 120) &&
             data.currency == "EUR" &&
             data.unitPrice is number &&
             data.unitPrice >= 0 &&
             hasValidUnitPrice(data.productSku, data.unitPrice) &&
             data.quantity is int &&
             data.quantity > 0 &&
             data.quantity <= 999 &&
             data.subtotal is number &&
             data.subtotal >= 0 &&
             data.discountPercent is number &&
             data.discountPercent >= 0 &&
             hasValidDiscountPercent(data.productSku, data.discountPercent) &&
             data.discountAmount is number &&
             data.discountAmount >= 0 &&
             data.discountAmount <= data.subtotal &&
             data.total is number &&
             data.total >= 0 &&
             data.total <= data.subtotal &&
             isValidOrderOptions(data.options, data.productSku) &&
             isStringWithMax(data.note, 500) &&
             isValidOrderContext(data.context) &&
             data.status == "new" &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Trees collection - users can manage their own trees
    match /trees/{treeId} {
      // Public trees are readable by anyone.
      // Private trees are readable only by their owner, or by any
      // authenticated user when the tree has active invite links
      // (hasInvites == true). The invite URL itself acts as the
      // access control — similar to "anyone with the link" sharing.
      allow read: if resource.data.privacy == "public" ||
                     (request.auth != null &&
                      resource.data.userId == request.auth.uid) ||
                     (request.auth != null &&
                      resource.data.hasInvites == true);
      
      // Allow creating trees if user is authenticated and setting themselves as owner
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid;
      
      // Allow updating/deleting only trees the user owns
      allow update, delete: if request.auth != null && 
                               resource.data.userId == request.auth.uid;
    }

    // Store orders - users can create and view only their own orders.
    match /storeOrders/{orderId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid &&
                       isValidStoreOrder(request.resource.data);

      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;

      allow update: if false;

      allow delete: if request.auth != null &&
                       resource.data.userId == request.auth.uid;
    }

    // Tree invites — the tree owner creates invite tokens; anyone with the
    // token can read the invite to learn which tree it unlocks.
    match /treeInvites/{inviteId} {
      // Anyone can read an invite if they know the ID (from the shareable link).
      // Invite documents only store tree metadata (treeId, ownerId, treeName,
      // role), not tree data itself, so public reads are safe. Actual tree
      // data is still protected by the /trees/{treeId} rules.
      allow read: if true;

      // Only the tree owner can create/delete invites for their trees.
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid &&
                       isNonEmptyString(request.resource.data.treeId, 120) &&
                       isNonEmptyString(request.resource.data.ownerId, 120) &&
                       isStringWithMax(request.resource.data.treeName, 160) &&
                       request.resource.data.role == "suggest" &&
                       request.resource.data.createdAt is timestamp;

      allow delete: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;

      allow update: if false;
    }

    // Tree suggestions — invited collaborators submit suggestions that are
    // reviewed by the tree owner.
    match /treeSuggestions/{suggestionId} {
      // The tree owner can read all suggestions for their trees.
      // The author can read their own suggestions.
      allow read: if request.auth != null &&
                     (resource.data.ownerId == request.auth.uid ||
                      resource.data.authorId == request.auth.uid);

      // Any authenticated user can create a suggestion if they set themselves
      // as the author and provide the required fields.
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasOnly(["treeId", "ownerId", "authorId", "authorName", "treeName", "message", "status", "createdAt"]) &&
                       request.resource.data.authorId == request.auth.uid &&
                       isNonEmptyString(request.resource.data.treeId, 120) &&
                       isNonEmptyString(request.resource.data.ownerId, 120) &&
                       isNonEmptyString(request.resource.data.authorId, 120) &&
                       isStringWithMax(request.resource.data.authorName, 120) &&
                       isStringWithMax(request.resource.data.treeName, 160) &&
                       isNonEmptyString(request.resource.data.message, 1000) &&
                       request.resource.data.status == "pending" &&
                       request.resource.data.createdAt is timestamp;

      // Only the tree owner can update (accept/dismiss) a suggestion.
      allow update: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid &&
                       request.resource.data.status in ["accepted", "dismissed"] &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "reviewedAt"]);

      // Owner or author can delete.
      allow delete: if request.auth != null &&
                       (resource.data.ownerId == request.auth.uid ||
                        resource.data.authorId == request.auth.uid);
    }

    // Shared trees — users save references to trees they were invited to
    // so those trees appear on their dashboard.
    match /sharedTrees/{docId} {
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;

      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasOnly(["userId", "treeId", "ownerId", "treeName", "inviteId", "addedAt"]) &&
                       isNonEmptyString(request.resource.data.userId, 120) &&
                       isNonEmptyString(request.resource.data.treeId, 120) &&
                       isNonEmptyString(request.resource.data.ownerId, 120) &&
                       isStringWithMax(request.resource.data.treeName, 160) &&
                       isStringWithMax(request.resource.data.inviteId, 120) &&
                       request.resource.data.addedAt is timestamp;

      allow delete: if request.auth != null &&
                       resource.data.userId == request.auth.uid;

      allow update: if false;
    }
  }
}
